{
  "name": "leathercad",
  "version": "1.0.0",
  "description": "Leather tooling and CAD workspace",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build-wasm": "emcc cpp/drawing.cpp -o src/drawing.js -O3 -s WASM=1 -s MODULARIZE=1 -s EXPORT_NAME='ToolingModule' -s EXPORTED_FUNCTIONS='[\"_process_stroke\",\"_get_line_count\",\"_get_lines_buffer\",\"_clear_scene\"]' -s EXPORTED_RUNTIME_METHODS='[\"ccall\",\"cwrap\",\"getValue\",\"setValue\"]'",
    "dist": "npm run build-wasm && electron-builder"
  },
  "devDependencies": {
    "electron": "^26.0.0",
    "electron-builder": "^24.6.0"
  },
  "build": {
    "appId": "com.username.leathercad",
    "productName": "LeatherCAD",
    "files": [
      "dist/**/*",
      "renderer.js",
      "drawing.js",
      "index.html",
      "assets/**/*",
      "package.json",
      "src/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icons/MacOS/icon.png"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "assets/icons/Windows/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "icon": "assets/icons/Linux/512x512.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "andrewroloff",
        "repo": "leatherCAD"
      }
    ]
  }
}